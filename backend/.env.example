# Environment
NODE_ENV=production

# Server
PORT=4000
FRONTEND_URL=https://publishify.fazcreateve.app

# Database (PostgreSQL dengan Supabase)
# Connect to Supabase via connection pooling (untuk production & queries)
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://your_user:your_password@your_host:5432/your_database?schema=public"
# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://your_user:your_password@your_host:5432/your_database?schema=public"

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-here-use-a-long-random-string
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here-use-a-different-long-random-string

# JWT Expiry - Web platform (default)
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# JWT Expiry - Web platform (explicit)
JWT_WEB_EXPIRES_IN=1h
JWT_WEB_REFRESH_EXPIRES_IN=7d

# JWT Expiry - Mobile platform (long-lived)
JWT_MOBILE_EXPIRES_IN=365d
JWT_MOBILE_REFRESH_EXPIRES_IN=365d

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
FRONTEND_AUTH_CALLBACK=http://localhost:3000/auth/callback
OAUTH_STATE_EXPIRY=300

# Redis Cloud Connection (PRODUCTION READY)
REDIS_HOST=your-redis-host.redns.redis-cloud.com
REDIS_PORT=10660
REDIS_USERNAME=default
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0

# Alternative Options (commented for reference):
# ------------------------------------------------
# Option 1: Local Redis (Docker)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
#
# Option 3: Upstash Redis (Serverless)
# REDIS_HOST=nearby-dolphin-12345.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-upstash-password
# REDIS_DB=0

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@publishify.com

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt,.jpg,.jpeg,.png
UPLOAD_DEST=./uploads

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_STORAGE_BUCKET=publishify-files

# Payment Gateway (contoh: Midtrans)
PAYMENT_SERVER_KEY=your-payment-server-key
PAYMENT_CLIENT_KEY=your-payment-client-key
PAYMENT_MERCHANT_ID=your-merchant-id

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs