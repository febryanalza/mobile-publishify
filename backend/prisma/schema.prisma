generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

model feedback_review {
  id            String        @id
  idReview      String
  bab           String?
  halaman       Int?
  komentar      String
  dibuatPada    DateTime      @default(now())
  review_naskah review_naskah @relation(fields: [idReview], references: [id], onDelete: Cascade)
}

model file {
  id             String   @id
  idPengguna     String
  namaFileAsli   String
  namaFileSimpan String   @unique
  ukuran         Int
  mimeType       String
  ekstensi       String
  tujuan         String
  path           String
  url            String
  urlPublik      String?
  idReferensi    String?
  deskripsi      String?
  diuploadPada   DateTime @default(now())
  pengguna       pengguna @relation(fields: [idPengguna], references: [id], onDelete: Cascade)

  @@index([idPengguna])
  @@index([idReferensi])
  @@index([tujuan])
}

model genre {
  id             String   @id
  nama           String   @unique
  slug           String   @unique
  deskripsi      String?
  aktif          Boolean  @default(true)
  dibuatPada     DateTime @default(now())
  diperbaruiPada DateTime
  naskah         naskah[]
}

model kategori {
  id             String     @id
  nama           String
  slug           String     @unique
  deskripsi      String?
  idInduk        String?
  aktif          Boolean    @default(true)
  dibuatPada     DateTime   @default(now())
  diperbaruiPada DateTime
  kategori       kategori?  @relation("kategoriTokategori", fields: [idInduk], references: [id])
  other_kategori kategori[] @relation("kategoriTokategori")
  naskah         naskah[]
}

model log_aktivitas {
  id         String    @id
  idPengguna String?
  jenis      String
  aksi       String
  entitas    String?
  idEntitas  String?
  deskripsi  String?
  ipAddress  String?
  userAgent  String?
  dibuatPada DateTime  @default(now())
  pengguna   pengguna? @relation(fields: [idPengguna], references: [id])

  @@index([dibuatPada])
  @@index([idPengguna])
}

model log_produksi {
  id            String        @id
  idPesanan     String
  tahapan       String
  deskripsi     String?
  dibuatPada    DateTime      @default(now())
  pesanan_cetak pesanan_cetak @relation(fields: [idPesanan], references: [id], onDelete: Cascade)
}

model naskah {
  id              String          @id
  idPenulis       String
  judul           String
  subJudul        String?
  sinopsis        String
  isbn            String?         @unique
  idKategori      String
  idGenre         String
  bahasaTulis     String          @default("id")
  jumlahHalaman   Int?
  jumlahKata      Int?
  status          status_naskah   @default(draft)
  urlSampul       String?
  urlFile         String?
  publik          Boolean         @default(false)
  biayaProduksi   Decimal?        @db.Decimal(10, 2)
  hargaJual       Decimal?        @db.Decimal(10, 2)
  diterbitkanPada DateTime?
  dibuatPada      DateTime        @default(now())
  diperbaruiPada  DateTime
  formatBuku      format_buku     @default(A5)
  genre           genre           @relation(fields: [idGenre], references: [id])
  kategori        kategori        @relation(fields: [idKategori], references: [id])
  pengguna        pengguna        @relation(fields: [idPenulis], references: [id])
  pesanan_cetak   pesanan_cetak[]
  review_naskah   review_naskah[]
  revisi_naskah   revisi_naskah[]
  tag_naskah      tag_naskah[]

  @@index([dibuatPada])
  @@index([idGenre])
  @@index([idKategori])
  @@index([idKategori, status])
  @@index([idPenulis])
  @@index([idPenulis, status])
  @@index([publik, diterbitkanPada])
  @@index([status, dibuatPada])
  @@index([status])
}

model notifikasi {
  id         String          @id
  idPengguna String
  judul      String
  pesan      String
  tipe       tipe_notifikasi @default(info)
  dibaca     Boolean         @default(false)
  url        String?
  dibuatPada DateTime        @default(now())
  pengguna   pengguna        @relation(fields: [idPengguna], references: [id], onDelete: Cascade)

  @@index([idPengguna, dibaca])
}

model oauth_state {
  id             String   @id
  state          String   @unique
  provider       String
  redirectUrl    String?
  kadaluarsaPada DateTime
  dibuatPada     DateTime @default(now())

  @@index([kadaluarsaPada], map: "idx_oauth_state_expiry")
  @@index([state], map: "idx_oauth_state_state")
}

model pembayaran {
  id                String            @id
  idPesanan         String            @unique
  idPengguna        String
  nomorTransaksi    String            @unique
  jumlah            Decimal           @db.Decimal(10, 2)
  metodePembayaran  metode_pembayaran
  status            status_pembayaran @default(tertunda)
  urlBukti          String?
  catatanPembayaran String?
  tanggalPembayaran DateTime?
  dibuatPada        DateTime          @default(now())
  diperbaruiPada    DateTime
  pengguna          pengguna          @relation(fields: [idPengguna], references: [id])
  pesanan_cetak     pesanan_cetak     @relation(fields: [idPesanan], references: [id])

  @@index([idPengguna, status])
  @@index([nomorTransaksi])
  @@index([status, dibuatPada])
  @@index([status])
}

model pengguna {
  id                         String           @id
  email                      String           @unique
  kataSandi                  String?
  telepon                    String?
  google_id                  String?          @unique
  facebook_id                String?          @unique
  apple_id                   String?          @unique
  provider                   String?
  avatar_url                 String?
  email_verified_by_provider Boolean          @default(false)
  aktif                      Boolean          @default(true)
  terverifikasi              Boolean          @default(false)
  emailDiverifikasiPada      DateTime?
  loginTerakhir              DateTime?
  dibuatPada                 DateTime         @default(now())
  diperbaruiPada             DateTime
  file                       file[]
  log_aktivitas              log_aktivitas[]
  naskah                     naskah[]
  notifikasi                 notifikasi[]
  pembayaran                 pembayaran[]
  peran_pengguna             peran_pengguna[]
  pesanan_cetak              pesanan_cetak[]
  profil_pengguna            profil_pengguna?
  profil_penulis             profil_penulis?
  review_naskah              review_naskah[]
  token_refresh              token_refresh[]

  @@index([google_id], map: "idx_pengguna_google_id")
  @@index([provider], map: "idx_pengguna_provider")
}

model pengiriman {
  id              String            @id
  idPesanan       String            @unique
  namaEkspedisi   String
  nomorResi       String?
  biayaPengiriman Decimal           @db.Decimal(10, 2)
  alamatTujuan    String
  namaPenerima    String
  teleponPenerima String
  status          status_pengiriman @default(diproses)
  tanggalKirim    DateTime?
  estimasiTiba    DateTime?
  tanggalTiba     DateTime?
  dibuatPada      DateTime          @default(now())
  diperbaruiPada  DateTime
  pesanan_cetak   pesanan_cetak     @relation(fields: [idPesanan], references: [id], onDelete: Cascade)
  tracking_log    tracking_log[]
}

model peran_pengguna {
  id             String      @id
  idPengguna     String
  jenisPeran     jenis_peran
  aktif          Boolean     @default(true)
  ditugaskanPada DateTime    @default(now())
  ditugaskanOleh String?
  pengguna       pengguna    @relation(fields: [idPengguna], references: [id], onDelete: Cascade)

  @@unique([idPengguna, jenisPeran])
}

model pesanan_cetak {
  id                String         @id
  idNaskah          String
  idPemesan         String
  idPercetakan      String?
  nomorPesanan      String         @unique
  jumlah            Int
  formatKertas      String
  jenisKertas       String
  jenisCover        String
  finishingTambahan String[]
  catatan           String?
  hargaTotal        Decimal        @db.Decimal(10, 2)
  status            status_pesanan @default(tertunda)
  tanggalPesan      DateTime       @default(now())
  estimasiSelesai   DateTime?
  tanggalSelesai    DateTime?
  diperbaruiPada    DateTime
  log_produksi      log_produksi[]
  pembayaran        pembayaran?
  pengiriman        pengiriman?
  naskah            naskah         @relation(fields: [idNaskah], references: [id])
  pengguna          pengguna       @relation(fields: [idPemesan], references: [id])

  @@index([idPemesan, status])
  @@index([nomorPesanan])
  @@index([status])
  @@index([status, tanggalPesan])
  @@index([tanggalPesan])
}

model profil_pengguna {
  id             String    @id
  idPengguna     String    @unique
  namaDepan      String?
  namaBelakang   String?
  namaTampilan   String?
  bio            String?
  urlAvatar      String?
  tanggalLahir   DateTime?
  jenisKelamin   String?
  alamat         String?
  kota           String?
  provinsi       String?
  kodePos        String?
  dibuatPada     DateTime  @default(now())
  diperbaruiPada DateTime
  pengguna       pengguna  @relation(fields: [idPengguna], references: [id], onDelete: Cascade)
}

model profil_penulis {
  id                String   @id
  idPengguna        String   @unique
  namaPena          String?
  biografi          String?
  spesialisasi      String[]
  totalBuku         Int      @default(0)
  totalDibaca       Int      @default(0)
  ratingRataRata    Decimal  @default(0) @db.Decimal(3, 2)
  namaRekeningBank  String?
  namaBank          String?
  nomorRekeningBank String?
  npwp              String?
  dibuatPada        DateTime @default(now())
  diperbaruiPada    DateTime
  pengguna          pengguna @relation(fields: [idPengguna], references: [id], onDelete: Cascade)
}

model rating_review {
  id             String   @id
  idNaskah       String
  idPengguna     String
  rating         Int
  ulasan         String?
  dibuatPada     DateTime @default(now())
  diperbaruiPada DateTime

  @@unique([idNaskah, idPengguna])
}

model review_naskah {
  id              String            @id
  idNaskah        String
  idEditor        String
  status          status_review     @default(ditugaskan)
  rekomendasi     rekomendasi?
  catatan         String?
  ditugaskanPada  DateTime          @default(now())
  dimulaiPada     DateTime?
  selesaiPada     DateTime?
  diperbaruiPada  DateTime
  feedback_review feedback_review[]
  pengguna        pengguna          @relation(fields: [idEditor], references: [id])
  naskah          naskah            @relation(fields: [idNaskah], references: [id], onDelete: Cascade)

  @@index([idEditor])
  @@index([idEditor, status])
  @@index([idNaskah])
  @@index([status, ditugaskanPada])
}

model revisi_naskah {
  id         String   @id
  idNaskah   String
  versi      Int
  catatan    String?
  urlFile    String
  dibuatPada DateTime @default(now())
  naskah     naskah   @relation(fields: [idNaskah], references: [id], onDelete: Cascade)

  @@unique([idNaskah, versi])
}

model statistik_naskah {
  id                 String   @id
  idNaskah           String   @unique
  totalDiunduh       Int      @default(0)
  totalDibaca        Int      @default(0)
  totalDibagikan     Int      @default(0)
  totalDicetak       Int      @default(0)
  ratingRataRata     Decimal  @default(0) @db.Decimal(3, 2)
  totalRating        Int      @default(0)
  terakhirDiperbarui DateTime
}

model tag {
  id         String       @id
  nama       String       @unique
  slug       String       @unique
  dibuatPada DateTime     @default(now())
  tag_naskah tag_naskah[]
}

model tag_naskah {
  id         String   @id
  idNaskah   String
  idTag      String
  dibuatPada DateTime @default(now())
  naskah     naskah   @relation(fields: [idNaskah], references: [id], onDelete: Cascade)
  tag        tag      @relation(fields: [idTag], references: [id], onDelete: Cascade)

  @@unique([idNaskah, idTag])
}

model token_refresh {
  id             String   @id
  idPengguna     String
  token          String   @unique
  platform       platform @default(web)
  kadaluarsaPada DateTime
  dibuatPada     DateTime @default(now())
  pengguna       pengguna @relation(fields: [idPengguna], references: [id], onDelete: Cascade)

  @@index([idPengguna, platform])
  @@index([token])
}

model tracking_log {
  id           String     @id
  idPengiriman String
  lokasi       String
  status       String
  deskripsi    String?
  waktu        DateTime   @default(now())
  pengiriman   pengiriman @relation(fields: [idPengiriman], references: [id], onDelete: Cascade)
}

enum format_buku {
  A4
  A5
  B5
}

enum jenis_peran {
  penulis
  editor
  percetakan
  admin
}

enum metode_pembayaran {
  transfer_bank
  kartu_kredit
  e_wallet
  virtual_account
  cod
}

enum platform {
  web
  mobile
}

enum rekomendasi {
  setujui
  revisi
  tolak
}

enum status_naskah {
  draft
  diajukan
  dalam_review
  perlu_revisi
  disetujui
  ditolak
  diterbitkan
}

enum status_pembayaran {
  tertunda
  diproses
  berhasil
  gagal
  dibatalkan
  dikembalikan
}

enum status_pengiriman {
  diproses
  dalam_perjalanan
  terkirim
  gagal
}

enum status_pesanan {
  tertunda
  diterima
  dalam_produksi
  kontrol_kualitas
  siap
  dikirim
  terkirim
  dibatalkan
}

enum status_review {
  ditugaskan
  dalam_proses
  selesai
  dibatalkan
}

enum tipe_notifikasi {
  info
  sukses
  peringatan
  error
}
